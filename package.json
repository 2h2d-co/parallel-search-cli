{
  "name": "parallel-search-cli",
  "version": "0.0.1-alpha.1",
  "description": "An unofficial zero-runtime-dependency CLI for the Parallel Search and Extract APIs",
  "homepage": "https://github.com/2h2d-co/parallel-search-cli#readme",
  "bugs": {
    "url": "https://github.com/2h2d-co/parallel-search-cli/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Kaan Ozdokmeci",
    "email": "kaan@2h2d.co",
    "url": "https://www.2h2d.co"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2h2d-co/parallel-search-cli.git"
  },
  "bin": {
    "parallel-search": "bin/parallel-search.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test --test-concurrency=1 test/*.test.ts",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@types/node": "^24",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6"
  },
  "engines": {
    "node": ">=24"
  }
}
